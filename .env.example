# Database
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://cabot:change_me_strong_password@localhost:5432/cabot

# Redis
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379

# Auth
JWT_SECRET=change_me_jwt_secret_min_32_chars

# Captcha backend (existing)
OPENAI_API_KEY=sk-proj-...
CAPMONSTER_API_KEY=...
TWOCAPTCHA_API_KEY=
CAPTCHA_ADMIN_KEY=your_admin_key
CAPTCHA_BACKEND_URL=http://localhost:8000
INTERNAL_API_KEY=change_me_internal_secret  # Used by workers to auth to captcha backend

# Email OTP (Gmail App Password — NOT your regular password)
# Setup: Google Account → Security → 2FA → App passwords → create one
GMAIL_USER=otp-receiver@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Telegram Bot
# Setup: @BotFather → /newbot → copy token
# Get chat ID: send a message to your bot, then curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ADMIN_CHAT_ID=123456789

# Proxies (Bright Data)
BRIGHTDATA_USERNAME=brd-customer-...
BRIGHTDATA_PASSWORD=...
BRIGHTDATA_ZONE=residential

# App
NODE_ENV=production
